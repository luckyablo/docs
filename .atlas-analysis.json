{
  "projectType": "sdk-library",
  "projectName": "Ablo Decks SDK",
  "projectDescription": "A typed TypeScript SDK for building Ablo slide decks programmatically — create decks, slides, charts, tables, and themes from code via the Ablo API.",
  "theme": "luma",
  "primaryColor": "#5B4CF5",
  "lightColor": "#EEF0FF",
  "darkColor": "#2D1FA3",
